FLASK_APP=app.py
FLASK_SECRET_KEY=change-me-to-a-random-string

# Cloud Run URL of the deployed Gap Detector service (no trailing slash)
GD_URL=https://gap-detector-agent-tbq24k2wna-ew.a.run.app

# Use Google-signed ID token auth for private Cloud Run. Keep true on GCP.
GD_AUTH=true

# Google Cloud project that hosts the BigQuery tables
BIGQUERY_PROJECT=project-62cd3637-0b98-4aa5-8d5

# How often the results page polls BigQuery for new Confidence Agent rows (seconds)
POLLING_INTERVAL_SECONDS=5

# How long the results page keeps polling before giving up (seconds)
POLLING_TIMEOUT_SECONDS=600

# HTTP timeout for triggering the Gap Detector endpoint from Flask (seconds)
PIPELINE_REQUEST_TIMEOUT_SECONDS=300
